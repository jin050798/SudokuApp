@page "/"
@using SudokuApp.Models
@using SudokuApp.Components
@using SudokuApp.Services
@inject SudokuService SudokuService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

@* 가짜 업무 화면 *@
<div id="fake-work" style="display:none;" @onclick="Undisguise">
    <div class="fake-header">
        <span>📊 Work Dashboard</span>
        <span style="font-size:11px; color:#555;">클릭하면 돌아가기</span>
    </div>
    <div class="fake-content">
        <div class="fake-sidebar">
            <div class="fake-menu active">📋 Weekly Report</div>
            <div class="fake-menu">📁 Documents</div>
            <div class="fake-menu">📧 Messages</div>
            <div class="fake-menu">📅 Schedule</div>
            <div class="fake-menu">⚙️ Settings</div>
        </div>
        <div class="fake-main">
            <div class="fake-toolbar">
                <span>File</span>
                <span>Edit</span>
                <span>View</span>
                <span>Insert</span>
                <span>Format</span>
                <span>Tools</span>
            </div>
            <div class="fake-table-wrap">
                <table class="fake-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Task</th>
                            <th>Assignee</th>
                            <th>Status</th>
                            <th>Due Date</th>
                            <th>Priority</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>001</td><td>Q1 Report Review</td><td>Kim</td><td class="status done">Done</td><td>2026-04-01</td><td class="priority high">High</td></tr>
                        <tr><td>002</td><td>API Integration</td><td>Lee</td><td class="status progress">In Progress</td><td>2026-04-15</td><td class="priority high">High</td></tr>
                        <tr><td>003</td><td>UI Redesign</td><td>Park</td><td class="status progress">In Progress</td><td>2026-04-20</td><td class="priority mid">Mid</td></tr>
                        <tr><td>004</td><td>DB Migration</td><td>Choi</td><td class="status todo">Todo</td><td>2026-04-25</td><td class="priority mid">Mid</td></tr>
                        <tr><td>005</td><td>Security Audit</td><td>Jung</td><td class="status todo">Todo</td><td>2026-04-30</td><td class="priority low">Low</td></tr>
                        <tr><td>006</td><td>Performance Test</td><td>Kim</td><td class="status todo">Todo</td><td>2026-05-05</td><td class="priority low">Low</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* 실제 스도쿠 *@
<div id="sudoku-app">
    <div class="game-container">
        <h2>S U D O K U</h2>

        <div class="difficulty-buttons">
            <button class="@(difficulty == "초급" ? "active" : "")"
                    @onclick='() => StartGame("초급")'>초급</button>
            <button class="@(difficulty == "중급" ? "active" : "")"
                    @onclick='() => StartGame("중급")'>중급</button>
            <button class="@(difficulty == "고급" ? "active" : "")"
                    @onclick='() => StartGame("고급")'>고급</button>
        </div>

        @if (board != null)
        {
            <SudokuGrid Board="board" OnCellClick="HandleCellClick" />

            <div class="memo-toggle">
                <button class="@(isMemoMode ? "active" : "")" 
                        @onclick="ToggleMemo">
                    ✏️ 메모 @(isMemoMode ? "ON" : "OFF")
                </button>
            </div>
            <div class="numpad">
                @for (int i = 1; i <= 9; i++)
                {
                    int num = i;
                    <button class="num-button" @onclick="() => InputNumber(num)">@num</button>
                }
                <button class="num-button erase" @onclick="EraseCell">지우기</button>
            </div>

            <div class="action-buttons">
                <button @onclick="CheckAnswer">정답 확인</button>
                <button @onclick="SharePuzzle">🔗 공유</button>
                <button @onclick='() => StartGame(difficulty)'>새 게임</button>
            </div>

            @if (!string.IsNullOrEmpty(message))
            {
                <p class="message @messageClass">@message</p>
            }
        }
    </div>
</div>

@code {
    private SudokuBoard? board;
    private string difficulty = "중급";
    private int selectedRow = -1;
    private int selectedCol = -1;
    private string message = "";
    private string messageClass = "";

    private bool isMemoMode = false;

    private void ToggleMemo()
    {
        isMemoMode = !isMemoMode;
    }

    // InputNumber 메서드 교체
    private void InputNumber(int num)
    {
        if (selectedRow < 0 || selectedCol < 0 || board == null) return;
        var cell = board.Cells[selectedRow, selectedCol];
        if (cell.IsGiven) return;

        if (isMemoMode)
        {
            // 메모 모드 - 토글 방식
            if (cell.Memo.Contains(num))
                cell.Memo.Remove(num);
            else
                cell.Memo.Add(num);
        }
        else
        {
            // 일반 모드 - 숫자 입력 & 메모 초기화
            cell.Value = num;
            cell.Memo.Clear();
            cell.IsError = false;
            message = "";
        }
    }

    // EraseCell 메서드 교체
    private void EraseCell()
    {
        if (selectedRow < 0 || selectedCol < 0 || board == null) return;
        var cell = board.Cells[selectedRow, selectedCol];
        if (cell.IsGiven) return;

        cell.Value = 0;
        cell.Memo.Clear();
        cell.IsError = false;
        message = "";
    }

    private async Task Undisguise()
    {
        await JSRuntime.InvokeVoidAsync("undisguise");
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("addKeyboardListener",
                DotNetObjectReference.Create(this));
            await JSRuntime.InvokeVoidAsync("addEscapeListener");
        }
    }
    [JSInvokable]
    public void HandleKeyPress(string key)
    {
        // 숫자 입력
        if (int.TryParse(key, out int num) && num >= 1 && num <= 9)
        {
            InputNumber(num);
        }

        // 지우기
        if (key == "Backspace" || key == "Delete")
        {
            EraseCell();
        }

        // 방향키 이동
        if (selectedRow >= 0 && selectedCol >= 0)
        {
            switch (key)
            {
                case "ArrowUp":
                    if (selectedRow > 0) HandleCellClick((selectedRow - 1, selectedCol));
                    break;
                case "ArrowDown":
                    if (selectedRow < 8) HandleCellClick((selectedRow + 1, selectedCol));
                    break;
                case "ArrowLeft":
                    if (selectedCol > 0) HandleCellClick((selectedRow, selectedCol - 1));
                    break;
                case "ArrowRight":
                    if (selectedCol < 8) HandleCellClick((selectedRow, selectedCol + 1));
                    break;
            }
        }

        StateHasChanged();
    }
    protected override void OnInitialized()
    {
        // URL에 퍼즐 파라미터 있으면 복원
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (query["puzzle"] != null)
        {
            StartGame(difficulty);
            board = SudokuService.DeserializeBoard(query["puzzle"]!, board!);
        }
        else
        {
            StartGame(difficulty);
        }
    }

    // 게임 시작
    private void StartGame(string diff)
    {
        difficulty = diff;
        board = SudokuService.GeneratePuzzle(difficulty);
        selectedRow = -1;
        selectedCol = -1;
        message = "";
        ClearSelection();
    }

    // 셀 클릭
    private void HandleCellClick((int row, int col) pos)
    {
        ClearSelection();
        selectedRow = pos.row;
        selectedCol = pos.col;
        board!.Cells[selectedRow, selectedCol].IsSelected = true;
    }

    // 정답 확인
    private void CheckAnswer()
    {
        if (board == null) return;
        SudokuService.ValidateBoard(board);

        if (SudokuService.IsComplete(board))
        {
            message = "🎉 정답입니다!";
            messageClass = "success";
        }
        else
        {
            message = "틀린 칸이 있어요. 빨간색을 확인해보세요!";
            messageClass = "error";
        }
    }

    // 공유 링크 생성
    private async Task SharePuzzle()
    {
        if (board == null) return;
        var encoded = SudokuService.SerializeBoard(board);
        var url = $"{Navigation.BaseUri}?puzzle={encoded}";
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", url);
        message = "링크가 복사됐어요!";
        messageClass = "success";
    }

    private void ClearSelection()
    {
        if (board == null) return;
        for (int r = 0; r < 9; r++)
            for (int c = 0; c < 9; c++)
                board.Cells[r, c].IsSelected = false;
    }
}